{
  "profile": {
    "name": "Qwen/Qwen2.5-7B-Instruct-AWQ max",
    "description": "RTX 4070 Ti Super 16GB profile with high context and aggressive GPU usage."
  },
  "vllm": {
    "model_name": "Qwen/Qwen2.5-7B-Instruct-AWQ",
    "gpu_memory_utilization": 0.9,
    "max_model_len": 32768,
    "max_num_seqs": 2,
    "max_num_batched_tokens": 32768,
    "swap_space": 8,
    "cpu_offload_gb": 2,
    "kv_cache_dtype": "fp8",
    "kv_offloading_size": 0,
    "quantization": "awq_marlin",
    "dtype": "auto",
    "trust_remote_code": true,
    "api_base": "http://localhost:8000/v1",
    "temperature": 0.7,
    "top_p": 0.9,
    "max_tokens": 4096
  },
  "embeddings": {
    "model": "sentence-transformers/all-MiniLM-L6-v2",
    "similarity_metric": "cosine"
  },
  "rag": {
    "top_k": 8
  },
  "chunking": {
    "max_chunk_size": 768,
    "overlap_size": 80,
    "similarity_treshold": 0.7
  },
  "database": {
    "chroma_persist_dir": "data/chroma_db",
    "collection_name": "documents"
  },
  "graph": {
    "alpha": 0.7,
    "beta": 0.3,
    "use_entities": true,
    "spacy_model": "ru_core_news_md",
    "edge_top_p": 0.65
  },
  "reranker": {
    "cross_encoder_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
    "cross_encoder_top_n": 24,
    "cross_encoder_weight": 0.5
  },
  "prompt": {
    "enable_context_limit": true,
    "max_context_tokens": 12000
  },
  "swap": {
    "threshold": 0.35,
    "prefetch_count": 8,
    "memory_check_interval": 80,
    "force_offload_on_iteration": 1,
    "retain_top_centrality_pct": 0.2,
    "eviction_ram_threshold_gb": 16.0
  },
  "retrieval": {
    "initial_top_k_multiplier": 4,
    "exclude_used_chunks": false,
    "min_similarity_score": 0.12,
    "bm25_weight": 0.4,
    "rrf_k": 30,
    "enable_sgas_filtering": true,
    "semantic_anchor_threshold": 0.7,
    "min_return_chunks": 6,
    "enable_dynamic_weights": true,
    "low_semantic_warning_threshold": 0.3
  },
  "api": {
    "host": "0.0.0.0",
    "port": 8080
  }
}
