{
  "profile": {
    "name": "google/gemma-4-E2B-it max",
    "description": "Text-only Gemma 4 E2B-it high-usage preset with a 16k context window and unquantized vLLM settings."
  },
  "vllm": {
    "model_name": "google/gemma-4-E2B-it",
    "gpu_memory_utilization": 0.8,
    "max_model_len": 16384,
    "max_num_seqs": 1,
    "max_num_batched_tokens": 16384,
    "swap_space": null,
    "cpu_offload_gb": null,
    "kv_cache_dtype": null,
    "kv_offloading_size": null,
    "quantization": "",
    "dtype": "auto",
    "trust_remote_code": true,
    "enforce_eager": true,
    "language_model_only": true,
    "limit_mm_per_prompt": {
      "image": 0,
      "audio": 0,
      "video": 0
    },
    "api_base": "http://localhost:8000/v1",
    "temperature": 0.7,
    "top_p": 0.9,
    "max_tokens": 2048,
    "request_timeout": 300
  },
  "embeddings": {
    "model": "sentence-transformers/all-MiniLM-L6-v2",
    "similarity_metric": "cosine"
  },
  "rag": {
    "top_k": 10
  },
  "chunking": {
    "max_chunk_size": 512,
    "overlap_size": 60,
    "similarity_treshold": 0.7
  },
  "database": {
    "chroma_persist_dir": "data/chroma_db",
    "collection_name": "documents"
  },
  "graph": {
    "alpha": 0.7,
    "beta": 0.3,
    "use_entities": true,
    "spacy_model": "ru_core_news_md",
    "edge_top_p": 0.6
  },
  "reranker": {
    "cross_encoder_model": "cross-encoder/ms-marco-MiniLM-L-6-v2",
    "cross_encoder_top_n": 20,
    "cross_encoder_weight": 0.5
  },
  "prompt": {
    "enable_context_limit": true,
    "max_context_tokens": 13000
  },
  "swap": {
    "enabled": false,
    "threshold": 0.35,
    "prefetch_count": 6,
    "memory_check_interval": 100,
    "force_offload_on_iteration": -1,
    "retain_top_centrality_pct": 0.2,
    "eviction_ram_threshold_gb": 14.0,
    "proactive_offload": false,
    "gpu_pressure_free_ratio": 0.15
  },
  "retrieval": {
    "initial_top_k_multiplier": 4,
    "exclude_used_chunks": false,
    "min_similarity_score": 0.12,
    "bm25_weight": 0.4,
    "rrf_k": 30,
    "enable_sgas_filtering": true,
    "semantic_anchor_threshold": 0.7,
    "min_return_chunks": 6,
    "enable_dynamic_weights": true,
    "low_semantic_warning_threshold": 0.3
  },
  "api": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "benchmark": {
    "max_tokens": 128
  }
}
